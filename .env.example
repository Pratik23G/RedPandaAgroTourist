# Postgres connection string (Neon or Supabase free tier). Required before `db:migrate`/`db:seed` will work.
DATABASE_URL="postgresql://user:password@host:5432/redpanda?schema=public&sslmode=require"

# Resend transactional email (owner notification + customer auto-reply). Get from resend.com.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="bookings@redpandaagrotourist.com"
OWNER_NOTIFICATION_EMAIL="owner@redpandaagrotourist.com"

# Cloudflare Turnstile (spam protection on inquiry form). Get from dash.cloudflare.com/turnstile.
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Base site URL, used for metadata/OG tags/sitemap.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
